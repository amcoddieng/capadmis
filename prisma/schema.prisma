// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusDossier {
  non_demarre
  EN_COURS_D_ETUDE
  VALIDE
  CHANGEMENT_A_APPORTER
}

enum StatusAdmission {
  ADMISSION_EN_COURS
  ADMISSION_VALIDE
  ADMISSION_INVALIDE
}

enum StatusVisa {
  NON_DEMARRER
  DEMANDE_VISA_EN_COURS
  DEMANDE_VISA_VALIDE
  DEMANDE_VISA_INVALIDE
}

enum StatusInfosDossier {
  VALIDE
  EN_ATTENTE
  INVALIDE
}

enum TypeNotification {
  assignation_conseiller_admission
  assignation_conseiller_visa
  validation_dossier
  change_status
  message_recu
  demande_document
  demande_changement_document
  assignation_dossier
}

enum TypeCodeTemporaire {
  modification_mot_de_passe
  modification_infos
}

enum TypeUtilisateur {
  etudiant
  personnel
}

enum StatusPieceJointe {
  EN_COURS_DE_VERIFICATION
  A_CHANGER
  VALIDE
}

enum TypePieceJointe {
  PHOTO_PROFIL
  ATTESTATION
  DIPLOME_BAC
  RELEVE_NOTES_BAC
  DIPLOME_LICENCE
  DIPLOME_MASTER
  DIPLOME_DOCTORAT
  PASSEPORT
  CARTE_IDENTITE
  BULLETIN_NOTES_LICENCE_1
  BULLETIN_NOTES_LICENCE_2
  BULLETIN_NOTES_LICENCE_3
  BULLETIN_NOTES_MASTER_1
  BULLETIN_NOTES_MASTER_2
  BULLETIN_NOTES_DOCTORAT
  LETTRE_MOTIVATION
  CV
  BULLETIN_NOTES_SECONDE
  BULLETIN_NOTES_PREMIERE
  BULLETIN_NOTES_TERMINALE
  AUTRE
}

enum Role {
  superadmin
  admin
  conseiller_visa
  conseiller_admission
}

enum StatutDossierUniversite {
  accepte
  refuse
  en_attente
}

model personnel {
  id        Int      @id @default(autoincrement())
  prenom    String
  nom       String
  code      String   @unique
  email     String   @unique
  mdp       String
  role      Role
  bloque             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  dossiers_admission dossier[] @relation("ConseillerAdmissionDossiers")
  dossiers_visa      dossier[] @relation("ConseillerVisaDossiers")
}

model etudiant {
  id                Int      @id @default(autoincrement())
  nom               String
  prenom            String
  email             String   @unique
  mdp               String
  sexe              String
  ville             String
  payes             String
  date_de_naissance DateTime
  lieu_de_naissance String
  bloque            Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  dossier           dossier?
}

model dossier {
  id                      Int        @id @default(autoincrement())
  code_dossier            String     @unique
  etudiant_id             Int        @unique
  etudiant                etudiant   @relation(fields: [etudiant_id], references: [id], onDelete: Cascade)
  conseiller_admission_id Int?
  conseiller_admission    personnel? @relation("ConseillerAdmissionDossiers", fields: [conseiller_admission_id], references: [id])
  conseiller_visa_id      Int?
  conseiller_visa         personnel?    @relation("ConseillerVisaDossiers", fields: [conseiller_visa_id], references: [id])
  status                  StatusDossier @default(non_demarre)
  status_admission        StatusAdmission?
  status_visa             StatusVisa?
  infos_dossier           infos_dossier?
  pieces_jointes          piece_jointe[]
  dossiers_universite     dossier_universite[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model infos_dossier {
  id              Int                @id @default(autoincrement())
  code_dossier    String             @unique
  dossier         dossier            @relation(fields: [code_dossier], references: [code_dossier], onDelete: Cascade)
  niveau_etude    String
  pays_souhaite   String
  filieres        String[]
  nombre_fois_bac Int
  status          StatusInfosDossier @default(EN_ATTENTE)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model piece_jointe {
  id            Int                @id @default(autoincrement())
  nom           String             @unique
  codeDossier   String
  dossier       dossier            @relation(fields: [codeDossier], references: [code_dossier], onDelete: Cascade)
  type          TypePieceJointe
  status        StatusPieceJointe  @default(EN_COURS_DE_VERIFICATION)
  date_creation DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model notification {
  id            Int              @id @default(autoincrement())
  type          TypeNotification
  message       String
  destination   String
  lu            Boolean          @default(false)
  date_creation DateTime         @default(now())
}

model code_temporaire {
  id               Int                @id @default(autoincrement())
  type             TypeCodeTemporaire
  code             String
  date_expiration  DateTime
  utilisateur      String
  type_utilisateur TypeUtilisateur
  utilise          Boolean            @default(false)
  date_creation    DateTime           @default(now())
}

model message {
  id            Int      @id @default(autoincrement())
  contenu       String?
  expediteur    String
  destinataire  String
  vu            Boolean  @default(false)
  date_creation DateTime @default(now())
}

model dossier_universite {
  id                 Int                     @id @default(autoincrement())
  code_dossier       String
  dossier            dossier                 @relation(fields: [code_dossier], references: [code_dossier], onDelete: Cascade)
  filiere            String
  universite         String
  pays               String
  ville              String
  region             String
  statut             StatutDossierUniversite @default(en_attente)
  message_universite String?
  date_depot         DateTime                @default(now())
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model refresh_token {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user_type String
  user_id   Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}
